plot(st_geometry(communes_Bretagne))
plot(st_geometry(communes_Bretagne), lwd= 0.5)
communes_Bretagne<-communes_Bretagne %>%
mutate(surf2=st_area(geom))
str(communes_Bretagne$surf2)
# Cela revient à diviser notre variable par 1000*1000. Une façon plus élégante est
#d'utiliser le convertisseur d'unités issu du package units : set_units()
communes_Bretagne <- communes_Bretagne %>%
mutate(surf2 = units::set_units(surf2, km*km))
str(communes_Bretagne$surf2)
communes_Bretagne$surf - communes_Bretagne$surf2
